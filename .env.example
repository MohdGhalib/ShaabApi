# قالب متغيّرات البيئة — انسخه إلى .env واملأ القيم الحقيقية.
# ⚠️ لا ترفع .env إلى git أبداً (مُستبعَد في .gitignore).
# الصيغة لمتغيّرات .NET المتداخلة: استخدم شَرطتين سفليتين __ بدل النقطة.

# قاعدة البيانات
ConnectionStrings__DefaultConnection=Server=HOST;Database=DB;User=USER;Password=STRONG_PASSWORD;CharSet=utf8mb4;

# مفتاح توقيع JWT — 32 حرفاً عشوائياً على الأقل (مثلاً: openssl rand -hex 48)
Jwt__Key=PUT_A_LONG_RANDOM_SECRET_HERE
Jwt__Issuer=ShaabApi
Jwt__ExpiryHours=12

# كلمات مرور الإدارة — دوّرها (لا تُعد استخدام القديمة المسرّبة)
AdminPanelPassword=PUT_NEW_ADMIN_PANEL_PASSWORD
SuperAdminPassword=PUT_NEW_SUPER_ADMIN_PASSWORD
# هاش كلمة مرور المدير الرئيسي (SHA-256 لكلمة المرور الجديدة)
AdminPasswordHash=PUT_NEW_SHA256_HASH

# توكن SSE — قيمة عشوائية طويلة
SseToken=PUT_A_LONG_RANDOM_SSE_TOKEN

# أصول CORS المسموح بها (مفصولة بفواصل) — للسيرفر الداخلي ضع عنوانه
ALLOWED_ORIGINS=http://localhost:8080,http://YOUR_INTERNAL_SERVER

# خدمة واتساب (whatsapp-service)
WA_SECRET=PUT_A_LONG_RANDOM_WA_SECRET
