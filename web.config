<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\ShaabApi.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess" />
      <!-- رفع حد حجم الطلب في IIS إلى ~220MB لرفع الفيديوهات (الافتراضي ~28.6MB يرفضها بخطأ 404.13) -->
      <security>
        <requestFiltering>
          <requestLimits maxAllowedContentLength="220000000" />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>
</configuration>
